---
layout: layouts/base.njk
title: null
description: null
---
<section class="hero">
  <div class="hero__eyebrow">live · updated on every push</div>
  <h1>{{ site.tagline }}</h1>
  <p class="lead">{{ site.description }}</p>
</section>

{% include "partials/ad-slot.njk" %}

<section class="log">
  {% for post in collections.posts %}
  <div class="log__entry">
    <div class="log__meta">{{ post.data.date | readableDate("LLL d") }}<br>{{ post.data.date | readableDate("yyyy") }}</div>
    <div class="log__rail"><div class="log__dot"></div></div>
    <div class="log__card">
      {% set pTag = post.data.tags | primaryTag %}
      {% if pTag %}<span class="log__tag">#{{ pTag }}</span>{% endif %}
      <h2 class="log__title"><a href="{{ post.url }}">{{ post.data.title }}</a></h2>
      <p class="log__excerpt">{{ post.data.description or (post.templateContent | excerpt(150)) }}</p>
      <div class="log__foot">
        <span>#{{ post.fileSlug | shortSha }}</span>
        <span>{{ post.templateContent | readingTime }} min read</span>
      </div>
    </div>
  </div>
  {% else %}
  <div class="log__entry">
    <div class="log__meta"></div>
    <div class="log__rail"><div class="log__dot"></div></div>
    <div class="log__card">
      <h2 class="log__title">No entries yet</h2>
      <p class="log__excerpt">Add a Markdown file to <code>src/posts/</code> and push — this page rebuilds automatically.</p>
    </div>
  </div>
  {% endfor %}
</section>
