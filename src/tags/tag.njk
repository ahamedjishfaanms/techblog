---
layout: layouts/base.njk
pagination:
  data: collections.tagList
  size: 1
  alias: tag
permalink: /tags/{{ tag | slugify }}/
title: "#{{ tag }}"
description: "Posts tagged {{ tag }}"
eleventyComputed:
  title: "#{{ tag }}"
---
<section class="section">
  <p style="font-family: var(--font-mono); color: var(--muted); margin-bottom: 4px;"><a href="/tags/">← all tags</a></p>
  <h1>#{{ tag }}</h1>
</section>

<section class="log">
  {% for post in collections.posts %}
    {% if tag in post.data.tags %}
    <div class="log__entry">
      <div class="log__meta">{{ post.data.date | readableDate("LLL d") }}<br>{{ post.data.date | readableDate("yyyy") }}</div>
      <div class="log__rail"><div class="log__dot"></div></div>
      <div class="log__card">
        <h2 class="log__title"><a href="{{ post.url }}">{{ post.data.title }}</a></h2>
        <p class="log__excerpt">{{ post.data.description or (post.templateContent | excerpt(150)) }}</p>
      </div>
    </div>
    {% endif %}
  {% endfor %}
</section>
